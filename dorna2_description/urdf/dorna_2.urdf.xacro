<?xml version="1.0"?>
<robot name="dorna_2" xmlns:xacro="http://ros.org/wiki/xacro">
  <!--
    Dorna 2 / 2S: 5-DOF robot arm
    DH parameters from dorna2-python/dorna2/dof_5_6.py
    Joint limits from Dorna 2 series user manual.

    model arg selects between "dorna_2" (d1=206.4mm) and "dorna_2s" (d1=218.47mm).

    Mesh coordinate mapping: STLs are in the CAD global frame (Dorna_2.step).
    CAD frame: arm extends in -Y, Z vertical, base axis at ~(19mm, 44.2mm) in XY.
    Visual origins transform CAD geometry into each link's local frame via:
      T_visual = T_world_link^{-1} @ T_cad_to_world
    where T_cad_to_world = Trans(cad_tx, cad_ty, d1 - cad_arm_z) @ RotZ(+PI/2).

    Link1 contains merged geometry from the original link1-link4 CAD assemblies.
    Links 2-4 use placeholder meshes. Only joint0 (base rotation) and joint1
    (shoulder pitch) produce visible mesh articulation.
  -->

  <xacro:include filename="$(find dorna2_description)/urdf/materials.xacro"/>

  <xacro:arg name="parent" default="world"/>
  <xacro:arg name="model" default="dorna_2"/>
  <xacro:arg name="use_mesh" default="true"/>

  <xacro:property name="PI" value="3.14159265358979"/>
  <xacro:property name="mesh_dir" value="package://dorna2_description/meshes/dorna_2"/>
  <xacro:property name="use_mesh" value="$(arg use_mesh)"/>
  <xacro:property name="model" value="$(arg model)"/>

  <!-- DH parameters (meters). d1 differs between 2 and 2S. -->
  <xacro:property name="d1_2" value="0.2064"/>
  <xacro:property name="d1_2s" value="0.21847"/>
  <xacro:property name="d1" value="${d1_2s if model == 'dorna_2s' else d1_2}"/>

  <xacro:property name="a2" value="0.09548"/>
  <xacro:property name="a3" value="0.2032"/>
  <xacro:property name="a4" value="0.1524"/>
  <xacro:property name="d5" value="0.04892"/>

  <!-- CAD frame alignment offsets (meters, after mesh 0.001 scale).
       Derived from the base rotation axis position in the CAD export. -->
  <xacro:property name="cad_tx" value="0.0442"/>
  <xacro:property name="cad_ty" value="-0.019"/>
  <xacro:property name="cad_arm_z" value="0.2423"/>

  <xacro:macro name="default_inertia" params="mass">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </xacro:macro>

  <link name="$(arg parent)"/>

  <!-- Base link -->
  <link name="base_link">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="${cad_tx} ${cad_ty} ${d1 - cad_arm_z}" rpy="0 0 ${PI/2}"/>
        <geometry><mesh filename="${mesh_dir}/base.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_black"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="${d1}" radius="0.05"/></geometry>
        <material name="dorna_black"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="0 0 ${d1/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${d1}" radius="0.05"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="1.5"/>
  </link>

  <joint name="base_fixed" type="fixed">
    <parent link="$(arg parent)"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Joint 0: base rotation -->
  <link name="link0">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="${cad_tx} ${cad_ty} ${-cad_arm_z}" rpy="0 0 ${PI/2}"/>
        <geometry><mesh filename="${mesh_dir}/link0.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="0.095" radius="0.04"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="${a2/2} 0 0" rpy="0 ${PI/2} 0"/>
      <geometry>
        <cylinder length="${a2}" radius="0.04"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="1.2"/>
  </link>

  <joint name="joint0" type="revolute">
    <parent link="base_link"/>
    <child link="link0"/>
    <origin xyz="0 0 ${d1}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-160*PI/180}" upper="${180*PI/180}" velocity="${225*PI/180}" effort="50"/>
  </joint>

  <!-- Joint 1: shoulder pitch. link1 carries merged arm geometry (link1-link4 CAD assemblies). -->
  <link name="link1">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="${cad_tx - a2} ${-cad_arm_z} ${-cad_ty}" rpy="${-PI/2} ${PI/2} 0"/>
        <geometry><mesh filename="${mesh_dir}/link1.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="0.203" radius="0.025"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="${a3/2} 0 0" rpy="0 ${PI/2} 0"/>
      <geometry>
        <cylinder length="${a3}" radius="0.025"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="0.8"/>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link0"/>
    <child link="link1"/>
    <origin xyz="${a2} 0 0" rpy="${PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${(-91 if model == 'dorna_2s' else -90)*PI/180}" upper="${(181 if model == 'dorna_2s' else 180)*PI/180}" velocity="${225*PI/180}" effort="50"/>
  </joint>

  <!-- Joint 2: placeholder mesh (geometry merged into link1) -->
  <link name="link2">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="${mesh_dir}/link2.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="0.152" radius="0.02"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="${a4/2} 0 0" rpy="0 ${PI/2} 0"/>
      <geometry>
        <cylinder length="${a4}" radius="0.02"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="0.6"/>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="${a3} 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-142*PI/180}" upper="${142*PI/180}" velocity="${240*PI/180}" effort="30"/>
  </joint>

  <!-- Joint 3: placeholder mesh -->
  <link name="link3">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="${mesh_dir}/link3.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="0.049" radius="0.015"/></geometry>
        <material name="dorna_dark_grey"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.015"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="0.2"/>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="${a4} 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-135*PI/180}" upper="${135*PI/180}" velocity="${1125*PI/180}" effort="10"/>
  </joint>

  <!-- Joint 4: wrist roll (continuous), placeholder mesh -->
  <link name="link4">
    <xacro:if value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="${mesh_dir}/link4.stl" scale="0.001 0.001 0.001"/></geometry>
        <material name="dorna_light_grey"/>
      </visual>
    </xacro:if>
    <xacro:unless value="${use_mesh}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder length="0.049" radius="0.012"/></geometry>
        <material name="dorna_light_grey"/>
      </visual>
    </xacro:unless>
    <collision>
      <origin xyz="0 0 ${d5/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${d5}" radius="0.012"/>
      </geometry>
    </collision>
    <xacro:default_inertia mass="0.1"/>
  </link>

  <joint name="joint4" type="continuous">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0" rpy="0 0 ${PI/2}"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="${1125*PI/180}"/>
  </joint>

  <!-- Flange -->
  <link name="flange">
    <xacro:default_inertia mass="0.05"/>
  </link>

  <joint name="flange_fixed" type="fixed">
    <parent link="link4"/>
    <child link="flange"/>
    <origin xyz="0 0 ${d5}" rpy="0 0 0"/>
  </joint>

  <!-- TCP -->
  <link name="tcp"/>

  <joint name="tcp_fixed" type="fixed">
    <parent link="flange"/>
    <child link="tcp"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
